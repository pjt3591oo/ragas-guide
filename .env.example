# ── 프로바이더 선택 ──────────────────────────────
# ollama (기본) | openai | claude | gemini
LLM_PROVIDER=ollama

# ── Ollama 설정 ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
LLM_MODEL=qwen2.5:latest
EMBEDDING_MODEL=nomic-embed-text

